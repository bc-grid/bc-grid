{
  "name": "@bc-grid/editors",
  "version": "0.6.0-alpha.3",
  "description": "Cell editor framework for bc-grid (planned; v0.1 ships placeholder)",
  "license": "UNLICENSED",
  "author": "John Cottrell <john@cot.dev>",
  "homepage": "https://github.com/bc-grid/bc-grid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bc-grid/bc-grid.git",
    "directory": "packages/editors"
  },
  "bugs": {
    "url": "https://github.com/bc-grid/bc-grid/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/*.tsx --format esm --dts --sourcemap --clean --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts src/*.tsx --format esm --dts --sourcemap --watch --tsconfig tsconfig.build.json",
    "type-check": "tsc -b"
  },
  "dependencies": {
    "@bc-grid/core": "workspace:*",
    "@bc-grid/react": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  }
}
