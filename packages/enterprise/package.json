{
  "name": "@bc-grid/enterprise",
  "version": "0.1.0-alpha.1",
  "description": "Enterprise-only bc-grid extensions (planned; v0.1 ships placeholder)",
  "license": "UNLICENSED",
  "author": "John Cottrell <john@cot.dev>",
  "homepage": "https://github.com/johncotdev/bc-grid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johncotdev/bc-grid.git",
    "directory": "packages/enterprise"
  },
  "bugs": {
    "url": "https://github.com/johncotdev/bc-grid/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "type-check": "tsc -b"
  },
  "dependencies": {
    "@bc-grid/core": "workspace:*",
    "@bc-grid/react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
