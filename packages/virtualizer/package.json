{
  "name": "@bc-grid/virtualizer",
  "version": "0.1.0-alpha.2",
  "description": "Virtualizer engine for bc-grid (Fenwick offsets, in-flight retention, RAF throttling)",
  "license": "UNLICENSED",
  "author": "John Cottrell <john@cot.dev>",
  "homepage": "https://github.com/bc-grid/bc-grid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bc-grid/bc-grid.git",
    "directory": "packages/virtualizer"
  },
  "bugs": {
    "url": "https://github.com/bc-grid/bc-grid/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/index.js",
