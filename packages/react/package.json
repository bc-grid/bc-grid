{
  "name": "@bc-grid/react",
  "version": "0.4.0",
  "description": "React layer for bc-grid — high-performance shadcn-native data grid",
  "license": "UNLICENSED",
  "author": "John Cottrell <john@cot.dev>",
  "homepage": "https://github.com/bc-grid/bc-grid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bc-grid/bc-grid.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/bc-grid/bc-grid/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --sourcemap --clean --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.tsx --format esm --dts --sourcemap --watch --tsconfig tsconfig.build.json",
    "type-check": "tsc -b"
  },
  "dependencies": {
    "@bc-grid/core": "workspace:*",
    "@bc-grid/virtualizer": "workspace:*",
    "@bc-grid/animations": "workspace:*",
    "@bc-grid/theming": "workspace:*",
    "@bc-grid/aggregations": "workspace:*",
    "@bc-grid/filters": "workspace:*",
    "@bc-grid/export": "workspace:*",
    "@bc-grid/server-row-model": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@bc-grid/editors": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
