{
  "name": "@bc-grid/theming",
  "version": "0.6.0-alpha.2",
  "description": "shadcn-native theming layer for bc-grid (CSS tokens + density classes)",
  "license": "UNLICENSED",
  "author": "John Cottrell <john@cot.dev>",
  "homepage": "https://github.com/bc-grid/bc-grid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bc-grid/bc-grid.git",
    "directory": "packages/theming"
  },
  "bugs": {
    "url": "https://github.com/bc-grid/bc-grid/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "sideEffects": ["./dist/styles.css"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean && cp src/styles.css dist/styles.css",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "type-check": "tsc -b"
  },
  "dependencies": {
    "@bc-grid/core": "workspace:*"
  }
}
