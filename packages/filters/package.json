{
  "name": "@bc-grid/filters",
  "version": "0.5.0",
  "description": "Filter primitives for bc-grid (planned; v0.1 ships placeholder)",
  "license": "UNLICENSED",
  "author": "John Cottrell <john@cot.dev>",
  "homepage": "https://github.com/bc-grid/bc-grid",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bc-grid/bc-grid.git",
    "directory": "packages/filters"
  },
  "bugs": {
    "url": "https://github.com/bc-grid/bc-grid/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "type-check": "tsc -b"
  },
  "dependencies": {
    "@bc-grid/core": "workspace:*"
  }
}
