---
import { Code } from "astro:components"
import DocsLayout from "../layouts/DocsLayout.astro"

const gridSnippet = `import { BcGrid, useBcGridApi, type BcGridColumn } from "@bc-grid/react"
import "@bc-grid/theming/styles.css"

type Customer = {
  id: string
  code: string
  name: string
  balance: number
  active: boolean
}

const columns: BcGridColumn<Customer>[] = [
  { field: "code", header: "Code", width: 120, pinned: "left", format: "code" },
  { field: "name", header: "Customer", minWidth: 240, flex: 1, filter: { type: "text" } },
  { field: "balance", header: "Balance", align: "right", format: "currency" },
]

const apiRef = useBcGridApi<Customer>()

<BcGrid
  data={customers}
  columns={columns}
  rowId={(row) => row.id}
  density="normal"
  defaultSort={[{ columnId: "code", direction: "asc" }]}
  apiRef={apiRef}
/>`

const themingSnippet = `/* Host app globals.css */
:root {
  --background: 0 0% 100%;
  --foreground: 222 47% 11%;
  --border: 214 32% 91%;
  --muted: 210 40% 96%;
  --muted-foreground: 215 16% 47%;
  --accent: 210 40% 96%;
  --ring: 221 83% 53%;
  --destructive: 0 84% 60%;
}

/* App entry */
