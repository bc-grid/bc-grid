---
import { Code } from "astro:components"
import DocsLayout from "../layouts/DocsLayout.astro"

const factorySnippet = `import type { BcCellEditor } from "@bc-grid/react"

export const colourEditor: BcCellEditor<unknown, string> = {
  Component: ColourEditor,
  // Discriminator surfaced as data-bc-grid-editor-kind on the input
  // wrapper so e2e selectors can target this editor specifically.
  kind: "colour",
  // Optional. Runs once before the component mounts; the resolved
  // value lands on \`props.prepareResult\`. Reject to abort activation
  // (the framework re-enters Navigation and announces the error).
  prepare: async ({ row, column }) => {
    return loadPaletteFor(row, column.columnId)
  },
}`

const componentSnippet = `import type { BcCellEditorProps } from "@bc-grid/react"
import { useId, useLayoutEffect, useRef, useState } from "react"

interface PaletteResult {
  swatches: readonly { hex: string; label: string }[]
}

function ColourEditor(props: BcCellEditorProps<unknown, string>) {
  const { initialValue, error, focusRef, seedKey, prepareResult, pending, column, commit, cancel } = props
  const palette = prepareResult as PaletteResult | undefined

  const triggerRef = useRef<HTMLButtonElement | null>(null)
  const [open, setOpen] = useState(true)
  const [draft, setDraft] = useState<string>(seedKey ?? initialValue ?? "")
  const errorId = useId()

  // Hand focusRef back in useLayoutEffect so the framework's
  // mount-focus call sees the assigned ref. useEffect is too late —
  // child layout effects fire before parent layout effects, so the
  // assignment lands before the framework reads focusRef.current.
  useLayoutEffect(() => {
    if (focusRef && triggerRef.current) {
      ;(focusRef as { current: HTMLElement | null }).current = triggerRef.current
    }
    return () => {
      if (focusRef) {
        ;(focusRef as { current: HTMLElement | null }).current = null
      }
    }
  }, [focusRef])

  const accessibleName =
    typeof column.header === "string"
      ? column.header
      : (column.field ?? column.columnId ?? "")

  return (
    <>
      <button
        ref={triggerRef}
        type="button"
        disabled={pending}
        aria-label={accessibleName}
        aria-invalid={error ? true : undefined}
        aria-describedby={error ? errorId : undefined}
        aria-haspopup="dialog"
        aria-expanded={open}
        data-bc-grid-editor-input="true"
        data-bc-grid-editor-kind="colour"
        onClick={() => setOpen((v) => !v)}
      >
        <span aria-hidden style={{ background: draft, width: 14, height: 14 }} />
        {draft || "Pick…"}
      </button>

      {open ? (
        // The popover lives inside the same DOM subtree as the trigger,
        // but if you portal to document.body apply
        // data-bc-grid-editor-portal so the framework's click-outside
        // path treats clicks inside the popover as part of the editor.
        <div
          role="dialog"
          aria-label={\`\${accessibleName} colour picker\`}
          data-bc-grid-editor-portal="true"
          className="colour-popover"
        >
          {(palette?.swatches ?? defaultPalette).map((s) => (
            <button
              key={s.hex}
              type="button"
              aria-label={s.label}
              onClick={() => {
                setDraft(s.hex)
                commit(s.hex)
              }}
              style={{ background: s.hex }}
            />
          ))}
          <button type="button" onClick={cancel}>
            Cancel
          </button>
        </div>
      ) : null}

      {error ? (
        <span id={errorId} className="visually-hidden">
          {error}
        </span>
      ) : null}
    </>
  )
}`

const typedCommitSnippet = `import type { BcCellEditorProps } from "@bc-grid/react"

// A numeric editor that owns its own keystroke interception and
// commits a typed \`number\` straight to the framework, bypassing
// \`column.valueParser\`. The opts.moveOnSettle override mirrors the
// keyboard model the wrapper would otherwise apply (Enter -> down,
// Tab -> right, Shift+Enter -> up, Shift+Tab -> left).
function TypedNumberEditor(props: BcCellEditorProps<unknown, number>) {
  const { initialValue, focusRef, seedKey, commit, cancel } = props
  const inputRef = useRef<HTMLInputElement | null>(null)
  // ...focusRef + select-all wiring elided for brevity...

  const tryCommit = (move: BcEditMove) => {
    const raw = inputRef.current?.value ?? ""
    const parsed = parseFloat(raw.replace(/,/g, ""))
    if (Number.isNaN(parsed)) return  // built-in validate; framework owns the error UI
    commit(parsed, { moveOnSettle: move })
  }

  const onKeyDown = (event: React.KeyboardEvent) => {
    if (event.key === "Enter") {
      event.preventDefault()
      event.stopPropagation()  // bypass the wrapper's onKeyDown
      tryCommit(event.shiftKey ? "up" : "down")
    } else if (event.key === "Tab") {
      event.preventDefault()
      event.stopPropagation()
      tryCommit(event.shiftKey ? "left" : "right")
    } else if (event.key === "Escape") {
      event.preventDefault()
      cancel()
    }
  }

  return (
    <input ref={inputRef} type="text" inputMode="decimal"
      defaultValue={seedKey ?? (initialValue == null ? "" : String(initialValue))}
      onKeyDown={onKeyDown} />
  )
}`

const wireSnippet = `import { BcEditGrid, type BcGridColumn } from "@bc-grid/react"
import { colourEditor } from "./colour-editor"

const columns: BcGridColumn<Item>[] = [
  { field: "name", header: "Name", flex: 1 },
  {
    field: "accent",
    header: "Accent",
    width: 160,
    editable: true,
    cellEditor: colourEditor,
    // Optional: validate before the overlay updates. Returning
    // { valid: false, error } keeps the editor open with the error
    // surfaced via aria-invalid + the assertive live region.
    validate: (value) =>
      /^#[0-9a-f]{6}$/i.test(value)
        ? { valid: true }
        : { valid: false, error: "Pick a hex colour." },
  },
]`

const commitSnippet = `<BcEditGrid<Item>
  data={items}
  columns={columns}
  rowId={(row) => row.id}
  onCellEditCommit={async (event) => {
    // event.previousValue / nextValue are the typed colour strings.
    // Returning a Promise marks the cell pending: true until it settles;
    // throwing rolls back the overlay and surfaces an assertive error.
    await api.updateAccent(event.rowId, event.nextValue as string)
  }}
/>`

const checklist = [
  "Factory exports a BcCellEditor with Component + optional prepare + optional kind discriminator.",
  "Component attaches focusRef in useLayoutEffect (not useEffect) so the framework's mount-focus call lands.",
  "Component cleans up focusRef.current = null in the layout-effect's return so a stale element reference doesn't leak after unmount.",
  "Component sets aria-label from column.header so AT announces the column context.",
  'Component sets aria-describedby pointing at a hidden span when error is present and aria-invalid="true" on the focusable input.',
  "Component disables its commit affordance while props.pending is true so Enter / Tab can't double-commit during async settle.",
  "Component renders props.error visibly so async validation rejection isn't silent.",
  "Component calls commit(value) exactly once on user confirmation, or cancel() to abort — never both, never twice.",
  "Component does NOT swallow Escape — forward it to props.cancel() or let the wrapper's onKeyDown handle it.",
  "Component does NOT bind activation or commit logic to Ctrl / Alt / Meta chords — those belong to the host shortcuts.",
  "Typed-value editors call event.stopPropagation() in their own onKeyDown and pass { moveOnSettle } to commit so the wrapper doesn't fire a duplicate string commit.",
  "Component uses prepareResult when the editor needs async setup (palettes, options, etc.).",
  "Popovered editors mark portaled content with data-bc-grid-editor-portal so click-outside doesn't fire inside the popover.",
  "Column wires the editor via column.cellEditor; validate runs at commit before the overlay updates.",
]
---

<DocsLayout
  title="Custom editor recipe"
  description="A worked colour-picker example walking the BcCellEditor factory contract end-to-end. Use this when you're shipping an editor not covered by the @bc-grid/editors built-ins."
  active="editor-custom-recipe"
>
  <section class="section">
    <h2>What you're building</h2>
    <p>
      A colour-picker cell editor that opens a popover, lets the user pick a swatch, and
      commits the hex string. The recipe covers everything the framework cares about:
      the factory shape, focus handoff, seed and prepare semantics, accessibility
      contract, the portal-aware click-outside marker, and the consumer-side wiring with
      <code>onCellEditCommit</code>.
    </p>
    <p>
      Most consumers do not need this — the
      <code>@bc-grid/editors</code> package ships built-ins for text, number, date,
      datetime, time, select, multi-select, and autocomplete. Reach for a custom editor
      when none of those fit (colour, file picker, mention chip, etc.).
    </p>
  </section>

  <section class="section">
    <h2>1. The factory</h2>
    <p>
      A custom editor is a <code>BcCellEditor</code> object: a React component, an
      optional <code>kind</code> discriminator, and an optional <code>prepare</code> hook.
      The framework runs <code>prepare</code> once between activation and mount; whatever
      it resolves to lands on the component as <code>props.prepareResult</code>.
    </p>
    <div class="code-shell">
      <div class="code-title">
        <span>colour-editor.tsx</span>
        <span>factory</span>
      </div>
      <Code code={factorySnippet} lang="ts" theme="github-dark" />
    </div>
  </section>

  <section class="section">
    <h2>2. The component</h2>
    <p>
      The framework gives the component an immutable snapshot of the cell
      (<code>initialValue</code>, <code>row</code>, <code>column</code>) plus four
      activation-aware props (<code>seedKey</code>, <code>pointerHint</code>,
      <code>prepareResult</code>, <code>pending</code>) and two callbacks
      (<code>commit</code>, <code>cancel</code>). Three details are easy to miss:
    </p>
    <ul>
      <li>
        <strong>focusRef in <code>useLayoutEffect</code></strong>. React commits child
        layout effects before parent layout effects. The framework reads
        <code>focusRef.current</code> in <em>its</em> useLayoutEffect to call
        <code>focus()</code>; if you assign in <code>useEffect</code> the ref is still
        <code>null</code> at that point and the input never receives DOM focus.
      </li>
      <li>
        <strong>aria-label from <code>column.header</code></strong>. The editor input owns
        DOM focus while editing, so AT announces it directly. Without an explicit name AT
        falls back to "edit text" with no column context.
      </li>
      <li>
        <strong>aria-describedby for errors</strong>. Pair with a visually-hidden span
        keyed by <code>useId()</code> so the validator's error message reaches AT
        regardless of whether focus is on the cell or the input.
      </li>
    </ul>
    <div class="code-shell">
      <div class="code-title">
        <span>colour-editor.tsx</span>
        <span>component</span>
      </div>
      <Code code={componentSnippet} lang="tsx" theme="github-dark" />
    </div>
  </section>

  <section class="section">
    <h2>3. Typed commit and custom move directives</h2>
    <p>
      The wrapper's keyboard handler reads the editor input's <code>value</code> string
      on Enter / Tab / Shift+Enter / Shift+Tab and commits it. That works for text
      editors, but numeric / date / select-style editors that already know their typed
      value would otherwise round-trip through <code>column.valueParser</code> just to
      reach the overlay. <code>commit</code> takes an optional second argument so an
      editor can pass a parsed value <em>and</em> the move directive directly:
    </p>
    <div class="code-shell">
      <div class="code-title">
        <span>typed-number-editor.tsx</span>
        <span>typed commit</span>
      </div>
      <Code code={typedCommitSnippet} lang="tsx" theme="github-dark" />
    </div>
    <p>
      <code>BcEditMove</code> is exported from <code>@bc-grid/react</code> and covers
      <code>"stay" | "down" | "up" | "right" | "left"</code>. Two rules to keep the
      handoff clean:
    </p>
    <ul>
      <li>
        Call <code>event.stopPropagation()</code> in the editor's
        <code>onKeyDown</code> so the wrapper's own Enter / Tab handler doesn't fire
        a second commit with the raw string value.
      </li>
      <li>
        When the editor commits a non-string value, the framework bypasses
        <code>column.valueParser</code> automatically — it's only invoked when
        <code>typeof value === "string"</code>. Editors that want to keep using
        <code>valueParser</code> should commit a string and rely on the wrapper.
      </li>
    </ul>
  </section>

  <section class="section">
    <h2>4. Portal-aware click-outside</h2>

    <p>
      The framework commits the current value on any document-level
      <code>pointerdown</code> outside the editor. If your editor renders a popover into a
      React portal — typical for date pickers, select menus, autocomplete dropdowns,
      anything that escapes the cell's overflow box — clicks inside that popover would
      otherwise look like "outside the editor" and trigger a premature commit.
    </p>
    <p>
      Mark the portaled content with <code>data-bc-grid-editor-portal</code>. The
      framework's click-outside handler walks <code>closest('[data-bc-grid-editor-root],
      [data-bc-grid-editor-portal]')</code> on the click target and ignores any match.
      The wrapper that hosts the editor's primary input already carries
      <code>data-bc-grid-editor-root</code>; you only need the portal marker on
      content rendered outside that wrapper.
    </p>
  </section>

  <section class="section">
    <h2>5. Wiring into a column</h2>
    <p>
      Attach the factory via <code>column.cellEditor</code>. <code>validate</code> runs
      after <code>valueParser</code> (string editors only) and before the overlay
      updates. Sync returns <code>BcValidationResult</code>; async returns
      <code>Promise&lt;BcValidationResult&gt;</code> with an optional
      <code>AbortSignal</code> 3rd arg for cancellation.
    </p>
    <div class="code-shell">
      <div class="code-title">
        <span>columns.ts</span>
        <span>wire-up</span>
      </div>
      <Code code={wireSnippet} lang="ts" theme="github-dark" />
    </div>
  </section>

  <section class="section">
    <h2>6. Consumer-side commit</h2>
    <p>
      <code>onCellEditCommit</code> fires after the optimistic overlay update lands.
      Returning a Promise marks the cell <code>pending: true</code> until it settles; on
      rejection the framework rolls back the overlay and surfaces an assertive
      announcement. Multiple cells can have <code>pending: true</code> concurrently — the
      framework does not serialise.
    </p>
    <div class="code-shell">
      <div class="code-title">
        <span>App.tsx</span>
        <span>commit</span>
      </div>
      <Code code={commitSnippet} lang="tsx" theme="github-dark" />
    </div>
  </section>

  <section class="section">
    <h2>7. Accessibility contract — what custom editors must mirror</h2>
    <p>
      Built-in editors (<code>text</code>, <code>number</code>, <code>date</code>,
      <code>select</code>, <code>multiSelect</code>, <code>autocomplete</code>,
      <code>checkbox</code>) all share a single accessibility contract. Custom
      editors must mirror it so AT users get the same announcements regardless
      of which editor is mounted.
    </p>

    <h3>Focus handoff</h3>
    <ul>
      <li>
        Assign <code>focusRef</code> from a <code>useLayoutEffect</code>, not a
        <code>useEffect</code>. React fires child layout effects before parent
        layout effects in the commit phase; the framework's parent layout effect
        calls <code>focusRef.current?.focus()</code> after mount, so the
        assignment must already be in place. <code>useEffect</code> runs after
        paint — too late; the framework reads <code>null</code> and gives up,
        leaving keyboard focus on the cell instead of the input. The default
        text editor uses this idiom (regression-pinned by an SSR test); custom
        editors MUST too.
      </li>
      <li>
        The cleanup of the same layout effect MUST null out <code>focusRef.current</code>.
        On unmount the framework's parent cleanup dispatches the
        <code>unmounted</code> event before the editor element is detached;
        a stale ref pointing at the about-to-disappear element can leak into
        consumer code that read it (e.g. logging). Mirror the built-in
        <code>text</code> / <code>number</code> editors here.
      </li>
      <li>
        The element you hand to <code>focusRef</code> SHOULD be the focusable
        affordance the user actually edits — the <code>&lt;input&gt;</code>,
        <code>&lt;select&gt;</code>, or trigger button. Composite editors
        (button + popover) hand the trigger so Tab / Shift+Tab on the wrapper
        cycle correctly when the popover is closed.
      </li>
    </ul>

    <h3>ARIA labelling and error linkage</h3>
    <ul>
      <li>
        <strong><code>aria-label</code></strong> — set from
        <code>column.header</code> (string headers) or
        <code>column.field</code> / <code>column.columnId</code> as a fallback.
        AT users tabbing into edit mode hear "Status, edit text" rather than
        the bare "edit text".
      </li>
      <li>
        <strong><code>aria-invalid</code></strong> — <code>true</code> when
        <code>props.error</code> is set, <code>undefined</code> otherwise.
        AT users hear "invalid" when the validator rejected the candidate
        value.
      </li>
      <li>
        <strong><code>aria-describedby</code></strong> — when
        <code>props.error</code> is set, point at a hidden
        <code>&lt;span id=&#123;errorId&#125;&gt;&#123;props.error&#125;&lt;/span&gt;</code>
        rendered inside the editor's DOM scope. Use <code>useId()</code> for
        the id so SSR / client renders agree. AT users hear the error text
        as the input's description after "invalid". Without
        <code>aria-describedby</code> the error is silent for AT.
      </li>
      <li>
        <strong>Don't rely on <code>role="alert"</code> for the error.</strong>
        The grid's polite + assertive live regions already announce validation
        rejections via <code>BcGridMessages</code>; layering a per-input
        alert role causes AT users to hear the error twice.
      </li>
    </ul>

    <h3>Pending and disabled treatment</h3>
    <ul>
      <li>
        When <code>props.pending</code> is <code>true</code>, set
        <code>disabled</code> on the focusable input. The framework's commit
        path serialises one pending validation at a time per cell, but a
        consumer's <code>onCellEditCommit</code> Promise can sit in flight
        for seconds; the disabled treatment prevents the user from re-firing
        the commit pipeline mid-flight (Enter / Tab stop working until it
        settles).
      </li>
      <li>
        On <code>data-bc-grid-editor-state="pending"</code> the bundled
        chrome paints a subtle disabled treatment via
        <code>--bc-grid-muted-fg</code> + 0.55 opacity. Custom editors
        get this for free if they set the same data attribute on the
        focusable element.
      </li>
      <li>
        Pending wins over error in the data-state precedence — the spinner
        chrome stays consistent when async commit is mid-flight after a
        prior validation rejection. <code>aria-invalid</code> still reflects
        the error so AT users hear the message during pending.
      </li>
    </ul>

    <h3>Portal click-outside</h3>
    <ul>
      <li>
        The framework attaches a document-level <code>pointerdown</code>
        listener and walks <code>event.target.closest("[data-bc-grid-editor-root],
        [data-bc-grid-editor-portal]")</code> to decide whether the click
        committed-on-outside or stayed inside the editor's logical scope.
      </li>
      <li>
        <code>data-bc-grid-editor-root="true"</code> is set on the editor
        wrapper by the framework — custom editors don't have to add it.
      </li>
      <li>
        <code>data-bc-grid-editor-portal="true"</code> is the consumer's opt-in
        for popovered content rendered outside the editor's DOM tree (date
        pickers, autocomplete dropdowns, custom shadcn / Radix popovers
        attached to <code>document.body</code>). Without it, clicks inside the
        popover commit the editor and dismiss the popover at the same time —
        the user can't pick from the popover.
      </li>
    </ul>

    <h3>What NOT to do</h3>
    <ul>
      <li>
        <strong>Don't hide the focusable input behind a custom focus
        manager.</strong> The framework's <code>focusRef</code> handoff
        assumes the input is keyboard-focusable as soon as it's in the DOM.
        A wrapper that puts the input in a hidden subtree and proxies clicks
        through breaks Tab / Shift+Tab, the assistive-tech focus walk, and
        the framework's <code>focus({ preventScroll: true })</code> call.
      </li>
      <li>
        <strong>Don't attach <code>onBlur</code> handlers that call
        <code>commit()</code>.</strong> Blur fires when the user tabs to the
        next cell, when the user clicks outside (already handled by the
        framework's pointerdown listener), and when an in-editor popover
        steals focus (bad). The framework's keyboard + click-outside paths
        cover the legitimate commit moments; an <code>onBlur</code> commit
        races with them and double-commits.
      </li>
      <li>
        <strong>Don't reach into the parent grid's DOM</strong> — the row
        containing your cell can disappear from the DOM at any time
        (virtualisation). The framework's in-flight retention keeps your
        cell alive while the editor is mounted, but neighbouring rows / cells
        are not stable. Read row data from <code>props.row</code>; column
        data from <code>props.column</code>.
      </li>
      <li>
        <strong>Don't render multiple focusable controls inside the
        editor.</strong> Tab / Shift+Tab inside the editor walks them, but
        the framework's wrapper-level Tab handler then commits with
        <code>moveOnSettle: "right"</code> — the user lands on the next
        grid cell, not the next editor control. If you genuinely need
        multiple inputs (e.g. a date-range editor with two dates), put the
        secondary input behind a popover marked
        <code>data-bc-grid-editor-portal</code> so Tab inside the popover
        doesn't trigger the wrapper's commit handler.
      </li>
      <li>
        <strong>Don't <code>setState</code> after <code>props.cancel()</code>.</strong>
        The framework unmounts the editor on the next render; the state
        update warns about updates on an unmounted component. If you need
        cleanup, do it in a <code>useLayoutEffect</code> cleanup.
      </li>
    </ul>
  </section>

  <section class="section">
    <h2>Checklist</h2>
    <ul>
      {checklist.map((item) => <li>{item}</li>)}
    </ul>
  </section>
</DocsLayout>
